# ============================================
# MEYOS — продакшн .env (шаблон)
# ============================================
# Скопируйте в .env на сервере и заполните значения.
# КРИТИЧНО: после правок выполните `php artisan config:clear && php artisan cache:clear`

APP_NAME=MEYOS
APP_ENV=production
APP_KEY=                          # обязательно: php artisan key:generate
APP_DEBUG=false                   # на проде ВСЕГДА false
APP_URL=https://meyos.uz          # ВНИМАНИЕ: точно тот же URL, по которому реально открывается сайт (со схемой, без trailing /)
APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru

# ============================================
# СЕССИИ — если не пускает в админку, проблема почти всегда здесь
# ============================================
SESSION_DRIVER=database           # рекомендуется на проде; file тоже работает
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

# SESSION_DOMAIN: оставьте пустым (null), если сайт на одном поддомене.
# Заполнять надо ТОЛЬКО если хотите расшарить сессию между поддоменами:
#   SESSION_DOMAIN=.meyos.uz   (с точкой!)
# Если сайт открывается по https и cookies не сохраняются — оставьте null.
SESSION_DOMAIN=null

# SESSION_SECURE_COOKIE: TRUE только если сайт работает по HTTPS.
# Если поставить true на сайте с HTTP — браузер не сохранит cookie и вход в админку не сработает!
SESSION_SECURE_COOKIE=true        # для HTTPS-сайта
SESSION_SAME_SITE=lax             # lax по умолчанию; для cross-domain SSO — none

# ============================================
# БД
# ============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=meyos
DB_USERNAME=meyos_user
DB_PASSWORD=                      # установить

# ============================================
# КЭШ
# ============================================
CACHE_STORE=database              # или file/redis
QUEUE_CONNECTION=database

# ============================================
# ПРОВЕРЕННЫЕ ПРОКСИ (если за nginx/cloudflare)
# ============================================
# Если фронт за прокси и Laravel «думает» что URL http а реально https → редирект-ловушка на логине.
# Добавьте в .env строку и убедитесь что TrustProxies настроен.
TRUSTED_PROXIES=*

# ============================================
# Прочее
# ============================================
LOG_CHANNEL=stack
LOG_LEVEL=warning                 # на проде не debug
MAIL_MAILER=log                   # пока почта не нужна
